---
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: {{ kubernetes_app_viewer_role_name }}
  namespace: {{ kubernetes_app_viewer_namespace }}
rules:
  - apiGroups: [""]
    resources:
      - pods
      - pods/log
      - services
      - endpoints
      - configmaps
    verbs:
      - get
      - list
      - watch

  - apiGroups: ["apps"]
    resources:
      - deployments
      - replicasets
    verbs:
      - get
      - list
      - watch

---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: {{ kubernetes_app_viewer_rolebinding_name }}
  namespace: {{ kubernetes_app_viewer_namespace }}
subjects:
  - kind: User
    name: {{ kubernetes_app_viewer_user }}
    apiGroup: rbac.authorization.k8s.io
  - kind: Group
    name: {{ kubernetes_app_viewer_group }}
    apiGroup: rbac.authorization.k8s.io
roleRef:
  kind: Role
  name: {{ kubernetes_app_viewer_role_name }}
  apiGroup: rbac.authorization.k8s.io
